# Public app URL used by links, redirects, SEO and future checkout callbacks.
APP_URL="https://funpace-run.vercel.app"

# API origin used by the registration form.
VITE_API_URL="http://localhost:3001"
API_PORT="3001"
API_PUBLIC_URL="https://funpace-run.vercel.app"
ALLOWED_ORIGINS="http://localhost:3000,http://127.0.0.1:3000,https://funpace-run.vercel.app"

# InfinitePay checkout integration.
PAYMENT_PROVIDER="infinitepay"
INFINITEPAY_HANDLE=lucas-romulo
PAYMENT_WEBHOOK_SECRET=""

# Supabase/Postgres database. Keep DATABASE_URL empty locally to use DATABASE_FILE.
DATABASE_PROVIDER="json"
DATABASE_URL=""
DATABASE_SSL="true"
DATABASE_FILE="data/funpace-db.json"
BACKUP_DIR="backups"
ADMIN_SESSION_SECRET=""
ADMIN_API_KEY="change-me"
